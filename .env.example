# Azure Communication Services Configuration
ACS_CONNECTION_STRING=endpoint=https://seefunnelmainservice2.unitedstates.communication.azure.com/;accesskey=your-key-here

# Your Azure Communication Services Phone Number (the one YOU purchased from Azure)
# CRITICAL: This must be a phone number you own through Azure Communication Services
# Get this from: Azure Portal -> Communication Services -> Phone Numbers
# Without this, call forwarding will NOT work!
SOURCE_PHONE=+18885551234

# The phone number you want to forward calls TO (can be any number)
TARGET_PHONE=+918392930664

# Your public callback URL (use ngrok for local testing)
CALLBACK_URL=https://your-domain.com/api/callbacks

# Server port (optional, defaults to 3000)
PORT=3000
